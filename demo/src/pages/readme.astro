---
import DemoLayout from '@/layouts/DemoLayout.astro'
import { Content as ReadmeContent } from '../../../README.md'

export const prerender = true
---

<DemoLayout title="WebMCP Kit README" description="WebMCP Kit README documentation">
  <section class="readme-shell">
    <header class="readme-header">
      <p>Repository README</p>
      <a href="/guide/">Open demo guide</a>
    </header>

    <article class="readme-document">
      <ReadmeContent />
    </article>
  </section>
</DemoLayout>

<script>
  import mermaid from 'mermaid'

  mermaid.initialize({
    flowchart: {
      htmlLabels: true
    },
    securityLevel: 'strict',
    startOnLoad: false,
    theme: 'base',
    themeVariables: {
      background: '#fffaf1',
      edgeLabelBackground: '#fffaf1',
      lineColor: '#2458ff',
      mainBkg: '#fffaf1',
      nodeBorder: '#2458ff',
      primaryBorderColor: '#2458ff',
      primaryColor: '#f7f3ec',
      primaryTextColor: '#141414',
      secondaryBorderColor: '#2458ff',
      secondaryColor: '#dfe6ff',
      secondaryTextColor: '#141414',
      tertiaryBorderColor: '#2458ff',
      tertiaryColor: '#ece6dc',
      tertiaryTextColor: '#141414'
    }
  })

  void renderReadmeMermaid()

  async function renderReadmeMermaid() {
    const diagrams = Array.from(
      document.querySelectorAll<HTMLElement>('pre[data-language="mermaid"], .readme-mermaid')
    ).map(function prepareMermaidBlock(block, index) {
      const source = block.textContent?.trim() ?? ''
      const diagram =
        block instanceof HTMLPreElement ? document.createElement('div') : block

      diagram.className = 'readme-mermaid'
      diagram.dataset.rendered = 'false'
      diagram.removeAttribute('data-processed')
      diagram.textContent = ''
      if (block instanceof HTMLPreElement) {
        block.replaceWith(diagram)
      }

      return {
        diagram,
        id: `readme-mermaid-${Date.now()}-${index}`,
        source
      }
    })

    for (const item of diagrams) {
      if (!item.source) continue

      try {
        const rendered = await mermaid.render(item.id, item.source)
        item.diagram.innerHTML = rendered.svg
        normalizeMermaidSvg(item.diagram)
        item.diagram.dataset.rendered = 'true'
      } catch (error) {
        item.diagram.dataset.error = 'true'
        item.diagram.dataset.rendered = 'true'
        item.diagram.textContent = item.source
        console.error('Mermaid render failed', error)
      }
    }
  }

  function normalizeMermaidSvg(diagram: HTMLElement) {
    const svg = diagram.querySelector('svg')
    if (!svg) return

    svg.removeAttribute('height')
    svg.setAttribute('width', '100%')
    svg.style.width = '100%'
    svg.style.maxWidth = '100%'
    svg.style.height = 'auto'

    const viewBox = svg.getAttribute('viewBox')?.split(/\s+/).map(Number)
    if (!viewBox || viewBox.length !== 4) return

    const [, , width, height] = viewBox
    if (width > 0 && height > 0) {
      svg.style.aspectRatio = `${width} / ${height}`
    }
  }
</script>

<style>
  .readme-shell {
    width: min(61.25rem, calc(100% - clamp(1.25rem, 4vw, 2rem)));
    margin: 0 auto;
    padding: clamp(1rem, 3vw, 1.5rem) 0 clamp(3rem, 8vw, 5rem);
  }

  .readme-header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 20px;
    border-bottom: 2px solid var(--demo-blue);
    padding-bottom: 14px;
    color: var(--demo-muted);
  }

  .readme-header p {
    margin: 0;
    color: var(--demo-blue);
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .readme-header a {
    border: 1px solid var(--demo-blue);
    color: var(--demo-blue);
    padding: 0.5rem 0.65rem;
    text-decoration: none;
  }

  .readme-header a:hover,
  .readme-header a:focus-visible {
    background: var(--demo-blue);
    color: var(--demo-paper-wash);
  }

  .readme-document a {
    color: var(--demo-blue);
    text-underline-offset: 0.2em;
  }

  .readme-document a:hover {
    text-decoration: underline;
  }

  .readme-document {
    color: var(--demo-muted);
    font-size: 1rem;
    line-height: 1.65;
  }

  .readme-document :global(h1),
  .readme-document :global(h2),
  .readme-document :global(h3) {
    color: var(--demo-ink);
    line-height: 1.15;
    text-wrap: balance;
  }

  .readme-document :global(h1) {
    margin: 0 0 1rem;
    color: var(--demo-blue);
    font-family: var(--demo-font-mono);
    font-size: clamp(2rem, 6vw, 3.5rem);
    line-height: 0.92;
    max-inline-size: 12ch;
    text-wrap: balance;
    text-transform: uppercase;
  }

  .readme-document :global(h2) {
    margin: 2.25rem 0 0.75rem;
    border-top: 1px solid var(--demo-rule-strong);
    padding-top: 1.5rem;
    font-size: clamp(1.35rem, 3vw, 2rem);
  }

  .readme-document :global(h3) {
    margin: 1.62rem 0 0.62rem;
    font-size: 1.2rem;
  }

  .readme-document :global(p),
  .readme-document :global(ul),
  .readme-document :global(ol) {
    margin: 0 0 1rem;
    text-wrap: pretty;
  }

  .readme-document :global(li + li) {
    margin-top: 6px;
  }

  .readme-document :global(code) {
    border: 1px solid var(--demo-blue-rule);
    background: rgba(36, 88, 255, 0.055);
    color: var(--demo-ink);
    padding: 0.08em 0.32em;
    font-family: var(--demo-font-mono);
    font-size: 0.92em;
  }

  .readme-document :global(:not(pre) > code) {
    overflow-wrap: anywhere;
  }

  .readme-document :global(pre) {
    overflow-x: auto;
    margin: 1rem 0 1.38rem;
    border: 1px solid rgba(36, 88, 255, 0.34);
    background: #14171f !important;
    color: #e7ecf4;
    padding: clamp(0.88rem, 2vw, 1.12rem);
    font-family: var(--demo-font-mono);
    font-size: 0.9rem;
    line-height: 1.65;
  }

  .readme-document :global(pre code) {
    border: 0;
    background: transparent;
    padding: 0;
    color: #e7ecf4;
  }

  .readme-document :global(pre .line) {
    min-height: 1.65em;
  }

  .readme-document :global(pre[data-language='mermaid']) {
    visibility: hidden;
  }

  .readme-document :global(.readme-mermaid) {
    overflow-x: auto;
    margin: 1.12rem 0 1.62rem;
    border: 1px solid var(--demo-blue-rule);
    background: var(--demo-paper-wash);
    color: var(--demo-ink);
    opacity: 0;
    padding: 1.12rem;
  }

  .readme-document :global(.readme-mermaid[data-rendered='true']) {
    opacity: 1;
  }

  .readme-document :global(.readme-mermaid[data-error='true']) {
    color: var(--demo-ink);
    white-space: pre;
  }

  .readme-document :global(.readme-mermaid svg) {
    display: block;
    width: 100%;
    max-width: 100%;
    height: auto;
    margin: 0 auto;
  }

  @media (max-width: 620px) {
    .readme-shell {
      width: min(100% - 1.25rem, 61.25rem);
    }

    .readme-document :global(pre),
    .readme-document :global(pre code),
    .readme-document :global(pre code *) {
      white-space: pre-wrap;
      overflow-wrap: anywhere;
    }
  }
</style>
