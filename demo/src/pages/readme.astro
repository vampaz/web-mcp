---
import DemoLayout from '@/layouts/DemoLayout.astro'
import { Content as ReadmeContent } from '../../../README.md'

export const prerender = true
---

<DemoLayout title="WebMCP Kit README" description="WebMCP Kit README documentation">
  <section class="readme-shell">
    <header class="readme-header">
      <p>Repository README</p>
    </header>

    <article class="readme-document">
      <ReadmeContent />
    </article>
  </section>
</DemoLayout>

<script>
  import mermaid from 'mermaid'

  mermaid.initialize({
    flowchart: {
      htmlLabels: true
    },
    securityLevel: 'strict',
    startOnLoad: false,
    theme: 'dark'
  })

  void renderReadmeMermaid()

  async function renderReadmeMermaid() {
    const diagrams = Array.from(
      document.querySelectorAll<HTMLElement>('pre[data-language="mermaid"], .readme-mermaid')
    ).map(function prepareMermaidBlock(block, index) {
      const source = block.textContent?.trim() ?? ''
      const diagram =
        block instanceof HTMLPreElement ? document.createElement('div') : block

      diagram.className = 'readme-mermaid'
      diagram.dataset.rendered = 'false'
      diagram.removeAttribute('data-processed')
      diagram.textContent = ''
      if (block instanceof HTMLPreElement) {
        block.replaceWith(diagram)
      }

      return {
        diagram,
        id: `readme-mermaid-${Date.now()}-${index}`,
        source
      }
    })

    for (const item of diagrams) {
      if (!item.source) continue

      try {
        const rendered = await mermaid.render(item.id, item.source)
        item.diagram.innerHTML = rendered.svg
        normalizeMermaidSvg(item.diagram)
        item.diagram.dataset.rendered = 'true'
      } catch (error) {
        item.diagram.dataset.error = 'true'
        item.diagram.dataset.rendered = 'true'
        item.diagram.textContent = item.source
        console.error('Mermaid render failed', error)
      }
    }
  }

  function normalizeMermaidSvg(diagram: HTMLElement) {
    const svg = diagram.querySelector('svg')
    if (!svg) return

    svg.removeAttribute('height')
    svg.setAttribute('width', '100%')
    svg.style.width = '100%'
    svg.style.maxWidth = '100%'
    svg.style.height = 'auto'

    const viewBox = svg.getAttribute('viewBox')?.split(/\s+/).map(Number)
    if (!viewBox || viewBox.length !== 4) return

    const [, , width, height] = viewBox
    if (width > 0 && height > 0) {
      svg.style.aspectRatio = `${width} / ${height}`
    }
  }
</script>

<style>
  .readme-shell {
    width: min(980px, calc(100% - 32px));
    margin: 0 auto;
    padding: 24px 0 80px;
  }

  .readme-header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 20px;
    border-bottom: 1px solid rgba(244, 240, 232, 0.16);
    padding-bottom: 14px;
    color: #9ea8a1;
  }

  .readme-header p {
    margin: 0;
    color: #e8be53;
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .readme-document a {
    color: #e8be53;
    text-underline-offset: 0.2em;
  }

  .readme-document a:hover {
    text-decoration: underline;
  }

  .readme-document {
    color: #d7ddd8;
    font-size: 1rem;
    line-height: 1.65;
  }

  .readme-document :global(h1),
  .readme-document :global(h2),
  .readme-document :global(h3) {
    color: #f4f0e8;
    line-height: 1.15;
  }

  .readme-document :global(h1) {
    margin: 0 0 16px;
    font-size: clamp(2rem, 6vw, 3.5rem);
  }

  .readme-document :global(h2) {
    margin: 36px 0 12px;
    border-top: 1px solid rgba(244, 240, 232, 0.14);
    padding-top: 24px;
    font-size: clamp(1.35rem, 3vw, 2rem);
  }

  .readme-document :global(h3) {
    margin: 26px 0 10px;
    font-size: 1.2rem;
  }

  .readme-document :global(p),
  .readme-document :global(ul),
  .readme-document :global(ol) {
    margin: 0 0 16px;
  }

  .readme-document :global(li + li) {
    margin-top: 6px;
  }

  .readme-document :global(code) {
    border: 1px solid rgba(244, 240, 232, 0.14);
    background: rgba(244, 240, 232, 0.08);
    color: #f4f0e8;
    padding: 0.08em 0.32em;
    font-family: SFMono-Regular, Consolas, Liberation Mono, monospace;
    font-size: 0.92em;
  }

  .readme-document :global(pre) {
    overflow-x: auto;
    margin: 16px 0 22px;
    border: 1px solid rgba(244, 240, 232, 0.14);
    background: #101514;
    padding: 16px;
  }

  .readme-document :global(pre code) {
    border: 0;
    background: transparent;
    padding: 0;
    color: #f4f0e8;
  }

  .readme-document :global(pre[data-language='mermaid']) {
    visibility: hidden;
  }

  .readme-document :global(.readme-mermaid) {
    overflow-x: auto;
    margin: 18px 0 26px;
    border: 1px solid rgba(244, 240, 232, 0.14);
    background: #101514;
    color: #d7ddd8;
    opacity: 0;
    padding: 18px;
  }

  .readme-document :global(.readme-mermaid[data-rendered='true']) {
    opacity: 1;
  }

  .readme-document :global(.readme-mermaid[data-error='true']) {
    color: #f4f0e8;
    white-space: pre;
  }

  .readme-document :global(.readme-mermaid svg) {
    display: block;
    width: 100%;
    max-width: 100%;
    height: auto;
    margin: 0 auto;
  }

  @media (max-width: 620px) {
    .readme-shell {
      width: min(100% - 20px, 980px);
      padding-top: 16px;
      padding-bottom: 48px;
    }
  }
</style>
