---
import DemoLayout from '@/layouts/DemoLayout.astro'
import { getDemoRouteStories } from '@/utils/demo-data'

const stories = getDemoRouteStories()
---

<DemoLayout
  title="WebMCP Kit Demo Guide"
  description="A concise guide to the WebMCP Kit demo flows"
>
  <section class="guide-shell">
    <header class="guide-header">
      <p>Demo guide</p>
      <h1>Natural language becomes safe, typed app actions.</h1>
      <span>
        Four routes show the same contract from different angles: current page context, narrow
        tools, planned input, app-owned execution, and approval for sensitive changes.
      </span>
    </header>

    <section class="guide-flow" aria-label="Demo flows">
      {
        stories.map(function renderStory(story, index) {
          return (
            <article>
              <span>{String(index + 1).padStart(2, '0')}</span>
              <h2>{story.title}</h2>
              <p>{story.buyerTakeaway}</p>
              <dl>
                <div>
                  <dt>Command</dt>
                  <dd>{story.guideCommand}</dd>
                </div>
                <div>
                  <dt>Expected tool call</dt>
                  <dd>{story.expectedToolCall}</dd>
                </div>
                <div>
                  <dt>Safety boundary</dt>
                  <dd>{story.safety}</dd>
                </div>
              </dl>
              <a href={story.path}>Open {story.navLabel}</a>
            </article>
          )
        })
      }
    </section>
  </section>
</DemoLayout>

<style>
  .guide-shell {
    display: grid;
    gap: clamp(1rem, 2vw, 1.5rem);
    width: min(73.75rem, calc(100% - clamp(1.25rem, 4vw, 2rem)));
    margin: 0 auto;
    padding: clamp(1rem, 3vw, 1.5rem) 0 clamp(3rem, 8vw, 5rem);
  }

  .guide-header {
    display: grid;
    gap: 0.65rem;
    border-bottom: 2px solid var(--demo-ink);
    padding-bottom: clamp(1rem, 2vw, 1.4rem);
  }

  .guide-header p,
  .guide-header h1,
  .guide-header span {
    margin: 0;
  }

  .guide-header p {
    color: var(--demo-blue);
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .guide-header h1 {
    color: var(--demo-blue);
    font-family: var(--demo-font-mono);
    font-size: clamp(2rem, 5vw, 4.4rem);
    line-height: 0.92;
    max-inline-size: 25ch;
    text-wrap: balance;
    text-transform: uppercase;
  }

  .guide-header span {
    max-inline-size: 60rem;
    color: var(--demo-muted);
    font-family: var(--demo-font-sans);
    font-size: clamp(1rem, 1.5vw, 1.18rem);
    line-height: 1.55;
    text-wrap: pretty;
  }

  .guide-flow {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1px;
    border: 1px solid var(--demo-rule-strong);
    background: var(--demo-rule-strong);
  }

  .guide-flow article {
    display: grid;
    min-width: 0;
    gap: 0.85rem;
    align-content: start;
    background: var(--demo-paper-wash);
    padding: clamp(1rem, 2vw, 1.35rem);
  }

  .guide-flow article > span {
    color: var(--demo-blue);
    font-size: 0.76rem;
    font-weight: 900;
  }

  .guide-flow h2,
  .guide-flow p,
  .guide-flow dl {
    margin: 0;
  }

  .guide-flow h2 {
    color: var(--demo-ink);
    font-size: clamp(1.4rem, 2.4vw, 2rem);
    line-height: 1.05;
    text-wrap: balance;
  }

  .guide-flow p {
    color: var(--demo-muted);
    line-height: 1.45;
  }

  .guide-flow dl {
    display: grid;
    gap: 0.75rem;
  }

  .guide-flow dt {
    color: var(--demo-muted);
    font-size: 0.7rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .guide-flow dd {
    margin: 0.16rem 0 0;
    color: var(--demo-ink);
    line-height: 1.4;
  }

  .guide-flow a {
    justify-self: start;
    border: 1px solid var(--demo-blue);
    color: var(--demo-blue);
    padding: 0.55rem 0.7rem;
    text-decoration: none;
  }

  .guide-flow a:hover,
  .guide-flow a:focus-visible {
    background: var(--demo-blue);
    color: var(--demo-paper-wash);
  }

  @media (max-width: 760px) {
    .guide-shell {
      width: min(100% - 1.25rem, 73.75rem);
    }

    .guide-flow {
      grid-template-columns: 1fr;
    }
  }
</style>
