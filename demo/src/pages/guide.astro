---
import DemoLayout from '@/layouts/DemoLayout.astro'
import { getDemoRouteStories } from '@/utils/demo-data'

const stories = getDemoRouteStories()
---

<DemoLayout
  title="WebMCP Kit Demo Guide"
  description="A concise guide to the WebMCP Kit demo flows"
>
  <section class="guide-shell">
    <header class="guide-header">
      <p>Demo guide</p>
      <h1>Natural language becomes safe, typed app actions.</h1>
      <span>
        Four routes show the same contract from different angles: current page context, narrow
        tools, planned input, app-owned execution, and approval for sensitive changes.
      </span>
    </header>

    <section class="guide-flow" aria-label="Demo flows">
      {
        stories.map(function renderStory(story, index) {
          return (
            <article>
              <span>{String(index + 1).padStart(2, '0')}</span>
              <h2>{story.title}</h2>
              <p>{story.buyerTakeaway}</p>
              <dl>
                <div>
                  <dt>Command</dt>
                  <dd>{story.guideCommand}</dd>
                </div>
                <div>
                  <dt>Expected tool call</dt>
                  <dd>{story.expectedToolCall}</dd>
                </div>
                <div>
                  <dt>Safety boundary</dt>
                  <dd>{story.safety}</dd>
                </div>
              </dl>
              <a href={story.path}>Open {story.navLabel}</a>
            </article>
          )
        })
      }
    </section>
  </section>
</DemoLayout>

<style>
  .guide-shell {
    display: grid;
    gap: clamp(1rem, 2vw, 1.5rem);
    width: min(1180px, calc(100% - 32px));
    margin: 0 auto;
    padding: 24px 0 80px;
  }

  .guide-header {
    display: grid;
    gap: 0.65rem;
    border-bottom: 1px solid rgba(244, 240, 232, 0.14);
    padding-bottom: clamp(1rem, 2vw, 1.4rem);
  }

  .guide-header p,
  .guide-header h1,
  .guide-header span {
    margin: 0;
  }

  .guide-header p {
    color: #e8be53;
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .guide-header h1 {
    max-width: 54rem;
    color: #f4f0e8;
    font-size: clamp(2rem, 5vw, 4.4rem);
    line-height: 0.98;
  }

  .guide-header span {
    max-width: 60rem;
    color: #aeb9b3;
    font-size: clamp(1rem, 1.5vw, 1.18rem);
    line-height: 1.55;
  }

  .guide-flow {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1px;
    border: 1px solid rgba(244, 240, 232, 0.13);
    background: rgba(244, 240, 232, 0.12);
  }

  .guide-flow article {
    display: grid;
    min-width: 0;
    gap: 0.85rem;
    align-content: start;
    background: rgba(9, 14, 13, 0.95);
    padding: clamp(1rem, 2vw, 1.35rem);
  }

  .guide-flow article > span {
    color: #e8be53;
    font-size: 0.76rem;
    font-weight: 900;
  }

  .guide-flow h2,
  .guide-flow p,
  .guide-flow dl {
    margin: 0;
  }

  .guide-flow h2 {
    color: #f4f0e8;
    font-size: clamp(1.4rem, 2.4vw, 2rem);
    line-height: 1.05;
  }

  .guide-flow p {
    color: #aeb9b3;
    line-height: 1.45;
  }

  .guide-flow dl {
    display: grid;
    gap: 0.75rem;
  }

  .guide-flow dt {
    color: #8fa098;
    font-size: 0.7rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .guide-flow dd {
    margin: 0.16rem 0 0;
    color: #e0e7e2;
    line-height: 1.4;
  }

  .guide-flow a {
    justify-self: start;
    border: 1px solid rgba(232, 190, 83, 0.44);
    color: #f4f0e8;
    padding: 0.55rem 0.7rem;
    text-decoration: none;
  }

  .guide-flow a:hover,
  .guide-flow a:focus-visible {
    border-color: #e8be53;
    color: #e8be53;
  }

  @media (max-width: 760px) {
    .guide-shell {
      width: min(100% - 20px, 1180px);
      padding-top: 16px;
      padding-bottom: 48px;
    }

    .guide-flow {
      grid-template-columns: 1fr;
    }
  }
</style>
