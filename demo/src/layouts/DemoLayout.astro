---
import '@/styles/global.css'
import { getDemoRouteStories } from '@/utils/demo-data'

interface Props {
  description?: string
  title?: string
}

const {
  description = 'Local WebMCP Kit demo',
  title = 'WebMCP Kit'
} = Astro.props
const currentPath = Astro.url.pathname
const isInventoryPage = currentPath === '/'
const demoRoutes = getDemoRouteStories()

function getIsActive(path: string): boolean {
  return path === '/'
    ? currentPath === '/'
    : currentPath.startsWith(path)
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#090b0b" />
    <link rel="icon" href="/webmcp-circuit.svg" type="image/svg+xml" />
    <title>{title}</title>
    <style is:inline>
      html,
      body {
        background: #090b0b;
      }
    </style>
  </head>
  <body>
    <header class="demo-topbar">
      <a class="demo-brand" href="/">WebMCP Kit</a>
      <nav class="demo-nav" aria-label="Demo sections">
        <a href="/guide/" aria-current={getIsActive('/guide/') ? 'page' : undefined}>Guide</a>
        {
          demoRoutes.map(function renderDemoRoute(route) {
            return (
              <a href={route.path} aria-current={getIsActive(route.path) ? 'page' : undefined}>
                {route.navLabel}
              </a>
            )
          })
        }
        <a href="/readme/" aria-current={getIsActive('/readme/') ? 'page' : undefined}>README</a>
      </nav>
    </header>

    <main class:list={['demo-shell', isInventoryPage && 'demo-shell--fixed']}>
      <slot />
    </main>
  </body>
</html>
