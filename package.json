{
  "name": "webmcp-kit",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "demo"
  ],
  "scripts": {
    "start": "npm --workspace @webmcp-kit/demo run start",
    "dev": "npm --workspace @webmcp-kit/demo run dev",
    "build": "npm --workspace @webmcp-kit/demo run build",
    "deploy": "npm --workspace @webmcp-kit/demo run deploy",
    "preview": "npm --workspace @webmcp-kit/demo run preview",
    "test": "vitest --run",
    "test:demo": "npm --workspace @webmcp-kit/demo run test",
    "test:e2e": "npm --workspace @webmcp-kit/demo run test:e2e",
    "test:watch": "vitest --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-svelte": "^3.17.1",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "svelte-eslint-parser": "^1.6.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=24.12.0"
  }
}
