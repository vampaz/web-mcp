{
  "name": "@vampaz/webmcp-kit",
  "version": "0.0.1",
  "type": "module",
  "description": "WebMCP tool registration, planners, framework helpers, devtools, and testing helpers for web apps.",
  "homepage": "https://github.com/vampaz/web-mcp#readme",
  "bugs": {
    "url": "https://github.com/vampaz/web-mcp/issues"
  },
  "license": "MIT",
  "author": "Carlos Rodrigues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vampaz/web-mcp.git"
  },
  "keywords": [
    "webmcp",
    "mcp",
    "browser-ai",
    "tools",
    "agents"
  ],
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/packages/core/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/packages/core/src/index.d.ts",
      "import": "./dist/index.js"
    },
    "./devtools": {
      "types": "./dist/packages/devtools/src/index.d.ts",
      "import": "./dist/devtools.js"
    },
    "./mcp-bridge": {
      "types": "./dist/packages/mcp-bridge/src/index.d.ts",
      "import": "./dist/mcp-bridge.js"
    },
    "./react": {
      "types": "./dist/packages/react/src/index.d.ts",
      "import": "./dist/react.js"
    },
    "./svelte": {
      "types": "./dist/packages/svelte/src/index.d.ts",
      "import": "./dist/svelte.js"
    },
    "./testing": {
      "types": "./dist/packages/testing/src/index.d.ts",
      "import": "./dist/testing.js"
    },
    "./testing/playwright": {
      "types": "./dist/packages/testing/src/playwright.d.ts",
      "import": "./dist/testing/playwright.js"
    },
    "./vue": {
      "types": "./dist/packages/vue/src/index.d.ts",
      "import": "./dist/vue.js"
    },
    "./zod": {
      "types": "./dist/packages/zod/src/index.d.ts",
      "import": "./dist/zod.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "test": "vitest --run",
    "test:watch": "vitest --watch",
    "lint": "oxlint .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check ."
  },
  "peerDependencies": {
    "@playwright/test": ">=1.60.0",
    "react": ">=19.2.6",
    "svelte": ">=5.55.5",
    "vue": ">=3.5.34",
    "zod": ">=4.4.3"
  },
  "peerDependenciesMeta": {
    "@playwright/test": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@vue/test-utils": "latest",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "react": "^19.2.6",
    "svelte": "^5.55.9",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.9",
    "vue": "^3.5.34",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=24.12.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
